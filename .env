N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=Your-User
N8N_BASIC_AUTH_PASSWORD=n8n-login
N8N_HOST=development.alphaagentx.com
N8N_PROTOCOL=https
N8N_SECURE_COOKIE=true
NODE_ENV=production
N8N_PORT=5678
WEBHOOK_URL=https://development.alphaagentx.com/
N8N_TRUSTED_PROXIES=*
# Enable External Runners
N8N_RUNNERS_ENABLED=true
N8N_RUNNERS_MODE=external
N8N_RUNNERS_AUTH_TOKEN=super-secret-runner-token
N8N_RUNNERS_BROKER_LISTEN_ADDRESS=0.0.0.0
N8N_NATIVE_PYTHON_RUNNER=true
