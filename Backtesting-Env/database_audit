      "parameters": {
        "jsCode": "const indicator = $('Loop Over Items14').first().json.indicator;\nconst input = $input.first().json;\n\n// 1️⃣ Find all array fields\nconst arrayKeys = Object.keys(input).filter(k => Array.isArray(input[k]));\n\n// ---------------------------------------------------\n// CASE 1 — Candle or Indicator arrays\n// ---------------------------------------------------\nif (arrayKeys.length > 0) {\n\n  // Reverse all arrays\n  const reversed = {};\n  for (const k of arrayKeys) {\n    reversed[k] = [...input[k]].reverse();\n  }\n\n  const candleCount = reversed[arrayKeys[0]].length;\n  const rows = [];\n\n  for (let i = 0; i < candleCount; i++) {\n    const row = {};\n\n    for (const key of arrayKeys) {\n      let col;\n\n      // Price candles\n      if ([\"open\",\"high\",\"low\",\"close\",\"volume\",\"timestamp\",\"timestampHuman\"].includes(key)) {\n        col = key;\n      }\n      // Indicator\n      else if (key.startsWith(\"value\")) {\n        const clean = key.replace(/^value/, \"\");\n        col = clean ? `${indicator}_${clean}` : `${indicator}_value`;\n      }\n      // Fallback\n      else {\n        col = `${indicator}_${key}`;\n      }\n\n      row[col] = reversed[key][i];\n    }\n\n    rows.push({ json: row });\n  }\n\n  return rows;\n}\n\n// ---------------------------------------------------\n// CASE 2 — Snapshot / Pattern / Trend endpoints\n// ---------------------------------------------------\n\nconst row = {};\n\nfor (const key of Object.keys(input)) {\n  if (typeof input[key] === \"number\") {\n    row[`${indicator}_${key}`] = input[key];\n  }\n  else if (typeof input[key] === \"string\") {\n    row[`${indicator}_${key}`] = input[key];\n  }\n}\n\nreturn [{ json: row }];\n"
      },
