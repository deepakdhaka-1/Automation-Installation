      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json).sort((a,b)=>a.timestamp-b.timestamp);\n\n// detect column like price_after_15_min / price_after_1h etc\nconst priceAfterKey = Object.keys(rows[0]).find(k => k.startsWith(\"price_after\"));\n\nrows.forEach((r,i)=>{\n  const next = rows[i+1];\n\n  if(next){\n\n    const current = Number(r.price_value);\n    const future = Number(next.price_value);\n\n    r[priceAfterKey] = future;\n\n    // percentage change\n    const pct = ((future - current) / current) * 100;\n\n    r.price_change = pct.toFixed(4);\n\n  } else {\n\n    r[priceAfterKey] = null;\n    r.price_change = null;\n\n  }\n});\n\nreturn rows.map(r => ({ json: r }));"
