N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=change-me
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_HOST=development.alphaagentx.com
N8N_PROTOCOL=https
N8N_SECURE_COOKIE=true
NODE_ENV=production
N8N_PORT=5678
WEBHOOK_URL=https://development.alphaagentx.com/
N8N_TRUSTED_PROXIES=127.0.0.1

# External runners are optional. Keep disabled unless runner containers are deployed.
N8N_RUNNERS_ENABLED=false
N8N_RUNNERS_MODE=external
N8N_RUNNERS_AUTH_TOKEN=change-me
N8N_RUNNERS_BROKER_LISTEN_ADDRESS=0.0.0.0
N8N_NATIVE_PYTHON_RUNNER=false
